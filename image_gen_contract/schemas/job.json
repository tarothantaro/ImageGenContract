{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tarostory.example/schemas/job.json",
  "title": "ImageGenJob",
  "description": "Message published to Pub/Sub topic image-gen-jobs. See ImageGenWorker/DESIGN.md §5.1.",
  "type": "object",
  "required": [
    "schema_version",
    "story_id",
    "user_id",
    "request_id",
    "type",
    "id",
    "input_images"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "story_id": { "type": "string", "minLength": 1 },
    "user_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "minLength": 1 },
    "type": { "type": "integer", "minimum": 1 },
    "id": { "type": "integer", "minimum": 1 },
    "input_images": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": ["photo_id", "position"],
        "additionalProperties": false,
        "properties": {
          "photo_id": { "type": "string", "minLength": 1 },
          "position": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
